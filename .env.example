# Google AI Studio / Gemini API key
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here

# Optional: Override default model
# Gemini models use :generateContent  → gemini-2.0-flash-exp (default)
# Imagen models use :predict           → imagen-3.0-generate-002
# GEMINI_MODEL=gemini-2.0-flash-exp

# PixelLab — purpose-built pixel art generation
# Get your token at: https://pixellab.ai/account
# PIXELLAB_API_KEY=your-api-token-here

# Optional: PixelLab model (pixflux or bitforge)
#   pixflux  — text-to-pixel-art, max 400x400 (default)
#   bitforge — style-guided, max 200x200
# PIXELLAB_MODEL=pixflux

# Optional: Stability AI
# STABILITY_API_KEY=your-key-here

# Optional: OpenAI / DALL-E
# OPENAI_API_KEY=your-key-here
